pipeline {
    agent any

    environment {
        // Define your two numbers here
        NUM1 = 5
        NUM2 = 10
    }

    stages {
        stage('Initialize') {
            steps {
                echo "Preparing to add ${env.NUM1} and ${env.NUM2}"
            }
        }

        stage('Addition') {
            steps {
                script {
                    // We use a script block for basic math logic
                    def sum = env.NUM1.toInteger() + env.NUM2.toInteger()
                    echo "The Total Sum is: ${sum}"
                }
            }
        }
    }

    post {
        success {
            echo "Math operation completed successfully!"
        }
    }
}jenkins
